{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beehiiv/subscribe-form",
	"version": "1.0.0",
	"title": "beehiiv Subscribe Form",
	"category": "beehiiv-blocks",
	"icon": "email-alt",
	"description": "Newsletter subscribe form powered by beehiiv.",
	"keywords": [ "beehiiv", "newsletter", "subscribe" ],
	"textdomain": "beehiiv",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"formId": {
			"type": "string",
			"default": ""
		}
	},
	"render": "file:./render.php",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
