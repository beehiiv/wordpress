{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beehiiv/signup-form",
	"version": "0.1.0",
	"title": "Beehiiv Signup Form",
	"category": "beehiiv-blocks",
	"icon": "email-alt",
	"description": "Newsletter signup form powered by Beehiiv.",
	"keywords": [ "beehiiv", "newsletter", "signup", "subscribe" ],
	"textdomain": "beehiiv",
	"supports": {
		"html": false,
		"anchor": true
	},
	"attributes": {
		"message": {
			"type": "string",
			"default": "Subscribe to our newsletter"
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css"
}
