{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "beehiiv/advertisement",
	"version": "1.0.0",
	"title": "beehiiv Advertisement",
	"category": "beehiiv-blocks",
	"icon": "megaphone",
	"description": "Places a beehiiv advertisement in the newsletter. Outputs nothing on the website.",
	"keywords": [ "beehiiv", "advertisement", "ad" ],
	"textdomain": "beehiiv",
	"supports": {
		"html": false,
		"anchor": true,
		"multiple": false
	},
	"attributes": {
		"adId": {
			"type": "string",
			"default": ""
		},
		"adLabel": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
