{
	"name": "beehiiv",
	"title": "Beehiiv",
	"description": "Official Beehiiv WordPress plugin.",
	"version": "1.0.0",
	"author": "",
	"license": "GPL-2.0-or-later",
	"main": "index.js",
	"keywords": [
		"newsletter",
		"email",
		"beehiiv"
	],
	"repository": {
		"type": "git",
		"url": "git@github.com:beehiiv/wordpress.git"
	},
	"bugs": {
		"url": "https://github.com/beehiiv/wordpress/issues"
	},
	"files": [
		"beehiiv.php",
		"build/",
		"includes/",
		"vendor/autoload.php",
		"vendor/composer/",
		"readme.txt"
	],
	"scripts": {
		"start": "wp-scripts start --webpack-src-dir=src/js",
		"build": "wp-scripts build --webpack-src-dir=src/js",
		"build:zip": "npm run build && composer install --no-dev --optimize-autoloader --prefer-dist --no-interaction --no-progress && node -e \"const fs=require('fs');const p='includes/OAuth/Config.php';const t=process.env.BEEHIIV_REGISTRATION_TOKEN||'';if(!t){console.error('BEEHIIV_REGISTRATION_TOKEN is required for build:zip');process.exit(1)}fs.writeFileSync(p,fs.readFileSync(p,'utf8').replace('BEEHIIV_REGISTRATION_TOKEN_PLACEHOLDER',t))\" && rm -rf dist && mkdir -p dist && composer archive --format=zip --dir=dist --file=beehiiv",
		"format": "wp-scripts format",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:php",
		"lint:js": "wp-scripts lint-js",
		"lint:js:fix": "wp-scripts lint-js --fix",
		"lint:css": "wp-scripts lint-style",
		"lint:css:fix": "wp-scripts lint-style --fix",
		"lint:php": "vendor/bin/phpcs",
		"lint:php:fix": "vendor/bin/phpcbf",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"env:destroy": "wp-env destroy"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@wordpress/api-fetch": "^7.45.0",
		"@wordpress/block-editor": "^15.18.0",
		"@wordpress/blocks": "^15.18.0",
		"@wordpress/components": "^33.0.0",
		"@wordpress/compose": "^7.45.0",
		"@wordpress/core-data": "^7.45.0",
		"@wordpress/data": "^10.45.0",
		"@wordpress/date": "^5.45.0",
		"@wordpress/edit-post": "^8.45.0",
		"@wordpress/editor": "^14.45.0",
		"@wordpress/element": "^6.45.0",
		"@wordpress/env": "^11.5.0",
		"@wordpress/hooks": "^4.45.0",
		"@wordpress/i18n": "^6.18.0",
		"@wordpress/icons": "^11.3.0",
		"@wordpress/plugins": "^7.45.0",
		"@wordpress/prettier-config": "^4.46.0",
		"@wordpress/scripts": "^32.1.0",
		"@wordpress/stylelint-config": "^23.38.0"
	}
}
