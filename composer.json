{
	"name": "beehiiv/beehiiv",
	"description": "Official beehiiv WordPress plugin",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"Beehiiv\\": "includes/"
		}
	},
	"minimum-stability": "stable",
	"require": {
		"php": ">=7.4"
	},
	"config": {
		"platform": {
			"php": "7.4"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-coding-standards/wpcs": "^3.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2"
	},
	"archive": {
		"exclude": [
			"!/build",
			"!/includes",
			"!/vendor/**",
			"!/readme.txt",
			"!/beehiiv.php",
			"!/composer.json",
			"!/languages/**",
			"src",
			"/src/**",
			"tests",
			"/tests/**",
			"bin",
			"/bin/**",
			"node_modules",
			".git",
			".github",
			"/.github/**",
			".vscode",
			"/dist",
			"/dist/**",
			"build-dev",
			"build-module",
			"build-style",
			"/README.md",
			"package.json",
			"package-lock.json",
			"composer.lock",
			"webpack.config.js",
			".stylelintrc.json",
			".npmrc",
			".stylelintignore",
			".prettierignore",
			".editorconfig",
			".prettierrc.js",
			".nvmrc",
			".wp-env.json",
			".wp-env.override.json",
			".gitignore",
			".phpcs.xml.dist",
			"**/*.zip",
			".DS_Store",
			"**/.DS_Store",
			"**/.gitkeep",
			"__MACOSX",
			"**/__MACOSX/**",
			".*"
		]
	}
}
