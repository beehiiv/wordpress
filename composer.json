{
	"name": "beehiiv/beehiiv",
	"description": "Official beehiiv WordPress plugin",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"autoload": {
		"psr-4": {
			"Beehiiv\\": "includes/"
		}
	},
	"minimum-stability": "stable",
	"require": {
		"php": ">=7.4"
	},
	"config": {
		"platform": {
			"php": "7.4"
		},
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	},
	"require-dev": {
		"phpunit/phpunit": "^9.6",
		"yoast/phpunit-polyfills": "^2.0",
		"wp-coding-standards/wpcs": "^3.3",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.2"
	},
	"archive": {
		"exclude": [
			"!/build",
			"!/includes",
			"!/vendor/autoload.php",
			"!/vendor/composer/**",
			"!/readme.txt",
			"!/beehiiv.php",
			"!/languages/**",
			"composer.json",
			"src",
			"/src/**",
			"tests",
			"/tests/**",
			"bin",
			"/bin/**",
			"scripts",
			"/scripts/**",
			"node_modules",
			"/vendor/bin",
			"/vendor/bin/**",
			"/vendor/phpunit",
			"/vendor/phpunit/**",
			"/vendor/sebastian",
			"/vendor/sebastian/**",
			"/vendor/phar-io",
			"/vendor/phar-io/**",
			"/vendor/theseer",
			"/vendor/theseer/**",
			"/vendor/myclabs",
			"/vendor/myclabs/**",
			"/vendor/nikic",
			"/vendor/nikic/**",
			"/vendor/yoast",
			"/vendor/yoast/**",
			"/vendor/squizlabs",
			"/vendor/squizlabs/**",
			"/vendor/phpcsstandards",
			"/vendor/phpcsstandards/**",
			"/vendor/phpcompatibility",
			"/vendor/phpcompatibility/**",
			"/vendor/dealerdirect",
			"/vendor/dealerdirect/**",
			"/vendor/wp-coding-standards",
			"/vendor/wp-coding-standards/**",
			".git",
			".github",
			"/.github/**",
			".vscode",
			".zed",
			"/dist",
			"/dist/**",
			"build-dev",
			"build-module",
			"build-style",
			"/README.md",
			"package.json",
			"package-lock.json",
			"composer.lock",
			"webpack.config.js",
			".stylelintrc.json",
			".npmrc",
			".stylelintignore",
			".prettierignore",
			".editorconfig",
			".prettierrc.js",
			".eslint.config.js",
			"mise.toml",
			".nvmrc",
			".wp-env.json",
			".wp-env.override.json",
			".wp-env.override.tmpl",
			"docker-compose.extra-hosts.example.yml",
			"docker-compose.extra-hosts.yml",
			".gitignore",
			".phpcs.xml.dist",
			"phpunit.xml",
			"phpunit.xml.dist",
			"**/*.zip",
			".DS_Store",
			"**/.DS_Store",
			"**/.gitkeep",
			"__MACOSX",
			"**/__MACOSX/**",
			".*"
		]
	}
}
