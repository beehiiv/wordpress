{
	"extends": "@wordpress/stylelint-config",
	"customSyntax": "postcss-scss",
	"rules": {
		"at-rule-no-unknown": [
			true,
			{
				"ignoreAtRules": [
					"use",
					"forward",
					"include",
					"mixin",
					"extend",
					"content"
				]
			}
		],
		"selector-class-pattern": "^[a-z0-9]+(-[a-z0-9]+)*(__[a-z0-9]+(-[a-z0-9]+)*)?(--[a-z0-9]+(-[a-z0-9]+)*)?$"
	}
}
